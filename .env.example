# Shared secret. Client apps use it directly on /resolve; admins exchange it at
# /login for a session. Use a long random string, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_MANAGER_TOKEN=

# Admin session lifetime in milliseconds (default 7 days = 604800000). The TTL
# slides on each authorized admin request (GET/POST on /keys).
SESSION_TTL_MS=604800000

# Port to listen on (default 4000).
PORT=4000

# Host to bind to (default 127.0.0.1). Set to 0.0.0.0 to expose beyond localhost.
# HOST=127.0.0.1

# Optional override for the JSON store path (default ./data.json).
# DATA_FILE=./data.json
